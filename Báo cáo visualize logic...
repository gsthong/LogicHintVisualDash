#cách dùng hàm main - fronten

from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import Alltools  # Import file logic của bạn

app = FastAPI()

# Cấu hình CORS để Frontend (index.html) có thể gọi API
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# Khai báo cấu trúc dữ liệu gửi lên từ Web
class CodeRequest(BaseModel):
    mode: str    # "online" hoặc "offline"
    choice: str  # "1", "2", hoặc "3"
    doc: str     # Đoạn mã nguồn cần phân tích

@app.post("/analyze")
async def analyze(request: CodeRequest):
    try:
        # Gọi hàm analyze_code từ file Alltools.py
        result = Alltools.analyze_code(request.mode, request.choice, request.doc)
        
        if "error" in result:
            raise HTTPException(status_code=400, detail=result["error"])
            
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)


